      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Service request retrieved by ID', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Correct service request returned', function () {",
              "    pm.expect(json.serviceRequestId).to.eql(parseInt(pm.environment.get('serviceRequestId')));",
              "});"
            ]
          }
        }
      ]
    },

