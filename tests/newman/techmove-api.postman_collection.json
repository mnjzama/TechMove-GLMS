{
  "info": {
    "name": "TechMove API CI Tests",
    "_postman_id": "techmove-api-tests",
    "description": "Newman CI tests for TechMove API running in Docker Compose.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "item": [

    {
      "name": "01 - API Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API is healthy', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "02 - Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set('email', `ci-${Date.now()}@test.com`);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Auth/Register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Auth", "Register"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register success OR already exists', function () {",
              "    pm.expect([200, 400]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.environment.set('token', json.token);",
              "    pm.environment.set('userId', json.userId);",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "03 - Login User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Auth/Login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Auth", "Login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login success', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.environment.set('token', json.token);",
              "pm.environment.set('userId', json.userId);"
            ]
          }
        }
      ]
    },

    {
      "name": "04 - Create Client",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Clients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Clients"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CI Client {{timestamp}}\",\n  \"contactDetails\": \"ci-client@test.com\",\n  \"region\": \"Limpopo\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Client created', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.environment.set('clientId', json.clientId || json.id);",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "04B - Get Clients",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Clients",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Clients"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Clients retrieved', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "04C - Get Client By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Clients/{{clientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Clients", "{{clientId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Client retrieved by ID', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Correct client returned', function () {",
              "    pm.expect(json.clientId).to.eql(parseInt(pm.environment.get('clientId')));",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "04D - Update Client",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Clients/{{clientId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Clients", "{{clientId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": {{clientId}},\n  \"name\": \"Updated CI Client\",\n  \"contactDetails\": \"updated@test.com\",\n  \"region\": \"Gauteng\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Client updated', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Client name updated', function () {",
              "    pm.expect(json.name).to.eql('Updated CI Client');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "05 - Create Contract",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/Contracts",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": {{clientId}},\n  \"serviceLevel\": \"Standard\",\n  \"startDate\": \"2026-01-01\",\n  \"endDate\": \"2026-12-31\",\n  \"agreementFilePath\": \"ci-test.pdf\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contract created', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.environment.set('contractId', json.contractId || json.id);",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "05B - Get Contract By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contracts/{{contractId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contracts", "{{contractId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contract retrieved by ID', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Correct contract returned', function () {",
              "    pm.expect(json.contractId).to.eql(parseInt(pm.environment.get('contractId')));",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "05C - Update Contract Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contracts/{{contractId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contracts", "{{contractId}}", "status"]
        },
        "body": {
          "mode": "raw",
          "raw": "1"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contract status updated', function () {",
              "    pm.expect([200, 204]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "05D - Delete Contract (or fail rule check)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contracts/{{contractId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contracts", "{{contractId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contract delete handled correctly', function () {",
              "    pm.expect([200, 204, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Get Contracts",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/Contracts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Contracts"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contracts retrieved', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "07 - Create Service Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ServiceRequests",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ServiceRequests"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contractId\": {{contractId}},\n  \"description\": \"CI Service Request\",\n  \"originalAmount\": 100,\n  \"currency\": \"USD\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Service request created', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "",
              "    pm.environment.set('serviceRequestId', json.serviceRequestId || json.id);",
              "",
              "    pm.test('Cost is calculated from exchange rate service', function () {",
              "        pm.expect(json.cost).to.be.greaterThan(0);",
              "    });",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "07B - Get Service Request By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
