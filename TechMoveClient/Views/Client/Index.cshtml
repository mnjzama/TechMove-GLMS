@model IEnumerable<TechMoveClient.Models.Client>

<h2 class="mb-3">Clients</h2>

<a href="/Client/Create" class="btn btn-primary mb-3">+ Add New Client</a>

<a href="/Contract/Index" class="btn btn-outline-secondary mb-3 ms-2">View Contracts</a>

<div class="card shadow-sm">
    <div class="card-body">

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Region</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.ContactDetails</td>
                    <td>@item.Region</td>
                    <td>
                        <a href="/Client/Edit/@item.ClientId" class="btn btn-sm btn-warning"> Edit </a>
                        @if (!item.HasContracts)
                        {
                            <form asp-action="Delete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@item.ClientId" />

                                <button type="submit"
                                        onclick="return confirm('Delete this client?');"
                                        class="btn btn-sm btn-danger">
                                    Delete
                                </button>
                            </form>
                        }
                        else
                        {
                            <span style="color:gray; font-size:12px;">Has contracts</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>

    </div>
</div>