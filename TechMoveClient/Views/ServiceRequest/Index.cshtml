@model IEnumerable<TechMoveClient.ViewModels.ServiceRequestViewModel>

<div class="container mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Service Requests</h2>

        <a href="/ServiceRequest/Create" class="btn btn-primary btn-sm">
            + New Request
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-hover table-bordered align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Client</th>
                        <th>Contract</th>
                        <th>Description</th>
                        <th>Original (USD/EUR)</th>
                        <th>Cost (ZAR)</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>

                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.ClientName</td>
                        <td>@r.ServiceLevel</td>
                        <td>@r.Description</td>
                        <td>
                            <strong>@r.Currency</strong><br />
                            @r.OriginalAmount
                        </td>
                        <td><strong>R @r.Cost</strong></td>

                        <td>
                            @if (r.Status.ToString() == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else if (r.Status.ToString() == "InProgress")
                            {
                                <span class="badge bg-info text-dark">In Progress</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Completed</span>
                            }

                            <form asp-action="UpdateStatus" method="post" class="mt-2">
                                <input type="hidden" name="id" value="@r.ServiceRequestId" />

                                <select name="status"
                                        class="form-select form-select-sm"
                                        onchange="this.form.submit()">

                                    <option value="Pending" selected="@(r.Status.ToString()=="Pending")">Pending</option>
                                    <option value="InProgress" selected="@(r.Status.ToString()=="InProgress")">In Progress</option>
                                    <option value="Completed" selected="@(r.Status.ToString()=="Completed")">Completed</option>

                                </select>
                            </form>
                        </td>    
                        <td>
                        @if (r.Status.ToString() == "Pending")
                            {
                                <form asp-action="Delete" method="post">
                                    <input type="hidden" name="id" value="@r.ServiceRequestId" />

                                    <button type="submit" class="btn btn-sm btn-danger w-100"
                                            onclick="return confirm('Are you sure you want to delete this request?');">
                                        Delete
                                    </button>
                                </form>
                            }
                        </td>                
                    </tr>
                }

                </tbody>

            </table>
        </div>
    </div>
</div>