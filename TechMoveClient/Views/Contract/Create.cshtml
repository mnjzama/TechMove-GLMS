@model TechMoveClient.ViewModels.ContractCreateViewModel

<div class="container mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Create Contract</h2>

        <a href="/Contract/Index" class="btn btn-secondary btn-sm">Back to Contracts</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label">Client</label>
                    <select asp-for="ClientId" asp-items="Model.Clients" class="form-select">
                        <option value="">-- Select Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Service Level</label>
                    <select asp-for="ServiceLevel" class="form-select">
                        <option value="">-- Select Level --</option>
                        <option value="Standard">Standard</option>
                        <option value="Express">Express</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Signed Agreement (PDF)</label>
                    <input type="file" asp-for="AgreementFile" accept=".pdf" class="form-control" />
                    <small class="text-muted">Only PDF files allowed</small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Contract</button>

                    <a href="/Contract/Index" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>

        </div>
    </div>

</div>